{
  "name": "habeeb-mohamed-ui-garden-build-checks",
  "version": "1.0.0",
  "private": true,
  "description": "WEBD-3012 Coding Assignment 13: React UI component library with Husky, Prettier, ESLint, tests, GitHub Actions, and Docker.",
  "dependencies": {
    "@testing-library/jest-dom": "5.17.0",
    "@testing-library/react": "13.4.0",
    "@testing-library/user-event": "13.5.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-scripts": "5.0.1",
    "web-vitals": "2.1.4"
  },
  "devDependencies": {
    "eslint-plugin-jest": "25.6.0",
    "husky": "9.1.7",
    "prettier": "3.6.2"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "react-scripts test --watchAll=false --passWithNoTests",
    "lint": "eslint \"src/**/*.{js,jsx}\" --max-warnings=0",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"public/**/*.html\" \"package.json\" \".github/workflows/*.yml\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\" \"public/**/*.html\" \"package.json\" \".github/workflows/*.yml\"",
    "quality": "npm run format:check && npm run lint && npm run test:ci",
    "ci": "npm run quality && npm run build",
    "prepare": "husky"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
